{
  "name": "pile-foundation-record",
  "version": "1.0.0",
  "description": "桩基施工记录桌面客户端 - 离线可用",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:electron": "cross-env USE_ELECTRON=true vite",
    "build": "tsc && vite build",
    "build:web": "tsc && vite build",
    "build:electron": "cross-env USE_ELECTRON=true tsc && vite build && electron-builder",
    "preview": "vite preview",
    "start": "electron .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.15.5",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.pile.record",
    "productName": "桩基施工记录系统",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  }
}
